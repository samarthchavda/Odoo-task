<odoo>
    <record id="free_product_add_form_view" model="ir.ui.view">
        <field name="name">free product add form</field>
        <field name="model">free.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="main_product_id"/>
                        <field name="free_product_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="is_active" readonly="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="free_product_add_list_view" model="ir.ui.view">
        <field name="name">free product add list</field>
        <field name="model">free.product</field>
        <field name="arch" type="xml">
            <tree>
                <field name="main_product_id"/>
                <field name="free_product_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="action_free_product" model="ir.actions.act_window">
        <field name="name">Add Free Product</field>
        <field name="res_model">free.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Free product"
              id="main_root_menu"
              />
    <menuitem name="Add Free Product"
              id="root_free_product_menu"
              parent="main_root_menu"
              action="action_free_product"
    />
</odoo>