<odoo>
    <record id="view_sale_extend_wizard_form" model="ir.ui.view">
        <field name="name">sale.extend.wizard.form</field>
        <field name="model">sale.extend.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Discount">
                <group>
                    <field name="discount_number"/>
                </group>
                <footer>
                    <button name="action_apply_discount" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sale_extend_wizard" model="ir.actions.act_window">
        <field name="name">add discount</field>
        <field name="res_model">sale.extend.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
